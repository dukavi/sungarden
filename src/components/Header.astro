---
import { Image } from 'astro:assets';
import type { Lang } from '../i18n/translations';
import { t, getLocalePath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import logoImg from '../images/logo_main.svg';

interface Props {
	lang?: Lang;
}

const { lang = 'fi' } = Astro.props;
---

<header>
	<div class="header-inner">
		<a href={getLocalePath(lang, '/')} class="logo">
			<img src={logoImg.src} alt="Aurinkotarha Mustio" width="56" height="56" class="logo-img" />
			{t(lang, 'site.title')}
		</a>
		<nav>
			<div class="nav-links">
				<a href={getLocalePath(lang, '/')}>{t(lang, 'nav.home')}</a>
				<a href={getLocalePath(lang, '/about')}>{t(lang, 'nav.about')}</a>
				<a href={getLocalePath(lang, '/blog')}>{t(lang, 'nav.blog')}</a>
				<a href={getLocalePath(lang, '/weather')}>{t(lang, 'nav.weather')}</a>
				<a href={getLocalePath(lang, '/sat-map')}>{t(lang, 'nav.satmap')}</a>
			</div>
			<LanguageSwitcher currentLang={lang} />
		</nav>
		<button class="menu-toggle" aria-label="Menu">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
				<line x1="4" y1="7" x2="20" y2="7"></line>
				<line x1="4" y1="17" x2="20" y2="17"></line>
			</svg>
		</button>
	</div>
</header>

<script>
	const toggle = document.querySelector('.menu-toggle');
	const nav = document.querySelector('header nav');
	toggle?.addEventListener('click', () => {
		nav?.classList.toggle('open');
	});
</script>

<style>
	header {
		background-color: var(--bg);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.header-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 4.5em;
	}
	.logo {
		text-decoration: none;
		color: var(--text);
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.3em;
		font-weight: 500;
		letter-spacing: 0.02em;
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.logo-img {
		width: 56px;
		height: 56px;
	}
	.logo:hover {
		color: var(--text);
		opacity: 0.7;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 2.5em;
	}
	.nav-links {
		display: flex;
		gap: 2em;
	}
	.nav-links a {
		text-decoration: none;
		color: var(--text);
		font-size: 0.75em;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-weight: 500;
		padding: 0.25em 0;
		border-bottom: 1px solid transparent;
		transition: border-color 0.3s ease, opacity 0.3s ease;
	}
	.nav-links a:hover {
		color: var(--text);
		border-bottom-color: var(--text);
		opacity: 0.7;
	}
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		color: var(--text);
		padding: 0.5em;
	}
	@media (max-width: 720px) {
		.header-inner {
			padding: 0 1.5em;
		}
		.menu-toggle {
			display: block;
		}
		nav {
			display: none;
			position: absolute;
			top: 4.5em;
			left: 0;
			right: 0;
			background: var(--bg);
			border-bottom: 1px solid var(--border);
			flex-direction: column;
			padding: 1.5em 2em;
			gap: 1.5em;
		}
		nav.open {
			display: flex;
		}
		.nav-links {
			flex-direction: column;
			gap: 1em;
		}
	}
</style>
