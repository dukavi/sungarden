---
import type { Lang } from '../i18n/translations';
import { t, getLocalePath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
	lang?: Lang;
}

const { lang = 'fi' } = Astro.props;
---

<header>
	<div class="header-inner">
		<a href={getLocalePath(lang, '/')} class="logo">
			<span class="logo-icon">&#9752;</span>
			<span class="logo-text">{t(lang, 'site.title')}</span>
		</a>
		<nav>
			<div class="nav-links">
				<a href={getLocalePath(lang, '/')}>{t(lang, 'nav.home')}</a>
				<a href={getLocalePath(lang, '/about')}>{t(lang, 'nav.about')}</a>
				<a href={getLocalePath(lang, '/blog')}>{t(lang, 'nav.blog')}</a>
			</div>
			<LanguageSwitcher currentLang={lang} />
		</nav>
		<button class="menu-toggle" aria-label="Menu">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<line x1="3" y1="6" x2="21" y2="6"></line>
				<line x1="3" y1="12" x2="21" y2="12"></line>
				<line x1="3" y1="18" x2="21" y2="18"></line>
			</svg>
		</button>
	</div>
</header>

<script>
	const toggle = document.querySelector('.menu-toggle');
	const nav = document.querySelector('header nav');
	toggle?.addEventListener('click', () => {
		nav?.classList.toggle('open');
	});
</script>

<style>
	header {
		background-color: var(--cream);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.header-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 4em;
	}
	.logo {
		text-decoration: none;
		color: var(--green-dark);
		display: flex;
		align-items: center;
		gap: 0.4em;
	}
	.logo-icon {
		font-size: 1.4em;
	}
	.logo-text {
		font-family: 'Playfair Display', Georgia, serif;
		font-size: 1.2em;
		font-weight: 600;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 2em;
	}
	.nav-links {
		display: flex;
		gap: 1.5em;
	}
	.nav-links a {
		text-decoration: none;
		color: var(--brown);
		font-size: 0.95em;
		padding: 0.25em 0;
		border-bottom: 2px solid transparent;
		transition: border-color 0.2s ease, color 0.2s ease;
	}
	.nav-links a:hover {
		color: var(--green);
		border-bottom-color: var(--green);
	}
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		color: var(--brown);
		padding: 0.5em;
	}
	@media (max-width: 720px) {
		.menu-toggle {
			display: block;
		}
		nav {
			display: none;
			position: absolute;
			top: 4em;
			left: 0;
			right: 0;
			background: var(--cream);
			border-bottom: 1px solid var(--border);
			flex-direction: column;
			padding: 1em 1.5em;
			gap: 1em;
		}
		nav.open {
			display: flex;
		}
		.nav-links {
			flex-direction: column;
			gap: 0.75em;
		}
	}
</style>
