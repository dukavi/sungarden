---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const SUPABASE_URL = 'https://oopcaomsmuqituowxpwi.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9vcGNhb21zbXVxaXR1b3d4cHdpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ0MTU5NjUsImV4cCI6MjA4OTk5MTk2NX0.SgKEfN5Aj9Uc6dVrTIHC2IG3A-M8Iiq2KHKYMu4zYHw';
const cities = ['Espoo', 'Helsinki', 'Vantaa', 'Kirkkonummi'];
---

<div class="order-form-wrapper" data-supabase-url={SUPABASE_URL} data-supabase-key={SUPABASE_KEY} data-lang={lang}>
	<h2 class="section-title">{t(lang, 'order.form.variety')}</h2>
	<div class="variety-grid" id="variety-grid"></div>

	<div class="order-summary" id="order-summary" hidden>
		<div class="summary-header">
			<span>{t(lang, 'order.form.total')}:</span>
			<span class="total-price">0 €</span>
		</div>
	</div>

	<div class="delivery-banner">
		<span class="delivery-free">{t(lang, 'order.delivery.free')}</span>
		<span>{t(lang, 'order.delivery.info')}</span>
		<span class="payment-note">{t(lang, 'order.payment.info')}</span>
	</div>

	<form id="order-form">
		<div class="form-grid">
			<div class="form-field">
				<label for="name">{t(lang, 'order.form.name')}</label>
				<input type="text" id="name" name="name" required />
			</div>
			<div class="form-field">
				<label for="phone">{t(lang, 'order.form.phone')}</label>
				<input type="tel" id="phone" name="phone" required />
			</div>
			<div class="form-field">
				<label for="email">{t(lang, 'order.form.email')}</label>
				<input type="email" id="email" name="email" required />
			</div>
			<div class="form-field">
				<label for="city">{t(lang, 'order.form.city')}</label>
				<select id="city" name="city" required>
					{cities.map(city => <option value={city}>{city}</option>)}
				</select>
			</div>
			<div class="form-field full-width">
				<label for="address">{t(lang, 'order.form.address')}</label>
				<input type="text" id="address" name="address" required />
			</div>
			<div class="form-field full-width">
				<label for="notes">{t(lang, 'order.form.notes')}</label>
				<textarea id="notes" name="notes" rows="3"></textarea>
			</div>
		</div>
		<div class="hp-field" aria-hidden="true">
			<input type="text" name="website" tabindex="-1" autocomplete="off" />
		</div>
		<button type="submit" class="submit-btn" disabled>{t(lang, 'order.form.submit')}</button>
		<p class="form-error" hidden>{t(lang, 'order.error')}</p>
	</form>

	<div class="success-message" hidden>
		<h2>{t(lang, 'order.success.title')}</h2>
		<p>{t(lang, 'order.success.text')}</p>
	</div>
</div>

<script is:inline>
(function () {
	var wrapper = document.querySelector('.order-form-wrapper');
	if (!wrapper) return;

	var url = wrapper.dataset.supabaseUrl;
	var key = wrapper.dataset.supabaseKey;
	var lang = wrapper.dataset.lang;
	var grid = document.getElementById('variety-grid');
	var summaryEl = document.getElementById('order-summary');
	var totalEl = wrapper.querySelector('.total-price');
	var form = document.getElementById('order-form');
	var submitBtn = form.querySelector('.submit-btn');
	var errorEl = wrapper.querySelector('.form-error');
	var successEl = wrapper.querySelector('.success-message');
	var varieties = [];
	var selections = {};

	function updateTotal() {
		var total = 0;
		var hasItems = false;
		for (var name in selections) {
			if (selections[name] > 0) {
				hasItems = true;
				var v = varieties.find(function (x) { return x.name === name; });
				if (v) total += selections[name] * v.price_per_box;
			}
		}
		totalEl.textContent = total + ' \u20AC';
		summaryEl.hidden = !hasItems;
		submitBtn.disabled = !hasItems;
	}

	function renderCard(v) {
		var card = document.createElement('div');
		card.className = 'variety-card';
		card.innerHTML =
			'<div class="variety-img-placeholder"></div>' +
			'<div class="variety-info">' +
				'<div class="variety-name">' + v.name + '</div>' +
				'<div class="variety-meta">' +
					'<span class="variety-type">' + v.type + '</span>' +
					'<span class="variety-pricing">' + v.price_per_box + ' \u20AC / ' + v.box_weight_kg + ' kg</span>' +
				'</div>' +
			'</div>' +
			'<div class="variety-check">\u2713</div>' +
			'<div class="variety-controls" hidden>' +
				'<button type="button" class="qty-btn qty-minus" disabled>\u2212</button>' +
				'<span class="qty-value">1</span>' +
				'<button type="button" class="qty-btn qty-plus">+</button>' +
			'</div>';

		var qtyVal = card.querySelector('.qty-value');
		var minusBtn = card.querySelector('.qty-minus');
		var plusBtn = card.querySelector('.qty-plus');
		var controls = card.querySelector('.variety-controls');

		selections[v.name] = 0;

		card.addEventListener('click', function (e) {
			if (e.target.closest('.variety-controls')) return;
			if (selections[v.name] > 0) {
				selections[v.name] = 0;
				card.classList.remove('selected');
				controls.hidden = true;
			} else {
				selections[v.name] = 1;
				qtyVal.textContent = '1';
				minusBtn.disabled = true;
				card.classList.add('selected');
				controls.hidden = false;
			}
			updateTotal();
		});

		plusBtn.addEventListener('click', function (e) {
			e.stopPropagation();
			var qty = Math.min(20, selections[v.name] + 1);
			selections[v.name] = qty;
			qtyVal.textContent = qty;
			minusBtn.disabled = false;
			updateTotal();
		});

		minusBtn.addEventListener('click', function (e) {
			e.stopPropagation();
			var qty = selections[v.name] - 1;
			if (qty <= 0) {
				selections[v.name] = 0;
				card.classList.remove('selected');
				controls.hidden = true;
			} else {
				selections[v.name] = qty;
				qtyVal.textContent = qty;
				minusBtn.disabled = qty <= 1;
			}
			updateTotal();
		});

		return card;
	}

	fetch(url + '/rest/v1/varieties?available=eq.true&select=name,type,price_per_kg,price_per_box,box_weight_kg&order=type,name', {
		headers: { 'apikey': key },
	}).then(function (r) { return r.json(); }).then(function (rows) {
		varieties = rows;
		rows.forEach(function (v) {
			grid.appendChild(renderCard(v));
		});
	});

	form.addEventListener('submit', async function (e) {
		e.preventDefault();
		errorEl.hidden = true;

		if (form.website.value) return;

		var items = [];
		var totalEur = 0;
		for (var name in selections) {
			if (selections[name] > 0) {
				var v = varieties.find(function (x) { return x.name === name; });
				var subtotal = selections[name] * v.price_per_box;
				items.push({ variety: name, quantity: selections[name], price_per_box: v.price_per_box, subtotal: subtotal });
				totalEur += subtotal;
			}
		}
		if (items.length === 0) return;

		var fd = new FormData(form);
		var itemsSummary = items.map(function (i) { return i.variety + ' x' + i.quantity; }).join(', ');
		var body = {
			customer_name: fd.get('name'),
			phone: fd.get('phone'),
			email: fd.get('email'),
			address: fd.get('address'),
			city: fd.get('city'),
			variety: itemsSummary,
			quantity: items.reduce(function (s, i) { return s + i.quantity; }, 0),
			total_eur: totalEur,
			notes: fd.get('notes') || null,
		};

		submitBtn.disabled = true;

		try {
			var res = await fetch(url + '/rest/v1/orders', {
				method: 'POST',
				headers: {
					'apikey': key,
					'Authorization': 'Bearer ' + key,
					'Content-Type': 'application/json',
					'Prefer': 'return=representation',
				},
				body: JSON.stringify(body),
			});

			if (res.ok) {
				var rows = await res.json();
				var orderId = rows[0] && rows[0].id;
				fetch(url + '/functions/v1/notify-order', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + key },
					body: JSON.stringify(Object.assign({ lang: lang, order_id: orderId, items: items }, body)),
				}).catch(function () {});
				form.hidden = true;
				grid.hidden = true;
				summaryEl.hidden = true;
				wrapper.querySelector('.delivery-banner').hidden = true;
				wrapper.querySelector('.section-title').hidden = true;
				successEl.hidden = false;
			} else {
				errorEl.hidden = false;
				submitBtn.disabled = false;
			}
		} catch (err) {
			errorEl.hidden = false;
			submitBtn.disabled = false;
		}
	});
})();
</script>

<style>
	.order-form-wrapper {
		max-width: 720px;
		margin: 0 auto;
	}

	.section-title {
		margin-bottom: 0.8em;
	}

	.variety-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1em;
		margin-bottom: 1.5em;
	}

	.variety-card {
		background: var(--card-bg);
		border: 2px solid var(--border);
		border-radius: 12px;
		padding: 1em;
		transition: border-color 0.2s, box-shadow 0.2s;
		cursor: pointer;
		position: relative;
		display: flex;
		flex-direction: column;
	}
	.variety-card:hover {
		border-color: var(--accent);
	}
	.variety-card.selected {
		border-color: var(--accent);
		box-shadow: 0 0 0 1px var(--accent);
	}

	.variety-check {
		position: absolute;
		top: 0.6em;
		right: 0.6em;
		width: 26px;
		height: 26px;
		border-radius: 50%;
		background: var(--border);
		color: transparent;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.85rem;
		font-weight: 700;
		transition: background 0.2s, color 0.2s;
	}
	.variety-card.selected .variety-check {
		background: var(--accent);
		color: #fff;
	}

	.variety-img-placeholder {
		width: 100%;
		aspect-ratio: 4/3;
		background: var(--bg-alt, #f2efe6);
		border-radius: 8px;
		margin-bottom: 0.8em;
	}

	.variety-info {
		flex: 1;
		margin-bottom: 0.5em;
	}
	.variety-name {
		font-weight: 600;
		font-size: 1.05rem;
		margin-bottom: 0.2em;
	}
	.variety-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.variety-type {
		font-size: 0.8rem;
		color: var(--text-muted);
		text-transform: capitalize;
	}
	.variety-pricing {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--accent);
	}

	.variety-controls {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.8em;
		padding-top: 0.8em;
		border-top: 1px solid var(--border);
	}
	.qty-btn {
		width: 32px;
		height: 32px;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: var(--bg);
		color: var(--text);
		font-size: 1.1rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.15s;
	}
	.qty-btn:hover:not(:disabled) {
		background: var(--bg-alt, #f2efe6);
	}
	.qty-btn:disabled {
		opacity: 0.3;
		cursor: not-allowed;
	}
	.qty-value {
		font-weight: 600;
		font-size: 1.1rem;
		min-width: 1.5em;
		text-align: center;
	}

	.order-summary {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1em 1.5em;
		margin-bottom: 1.5em;
	}
	.summary-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-weight: 600;
	}
	.total-price {
		font-size: 1.3rem;
		color: var(--accent);
	}

	.delivery-banner {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1em 1.5em;
		margin-bottom: 2em;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em 1.5em;
		align-items: center;
		font-size: 0.9rem;
		color: var(--text-muted);
	}
	.delivery-free {
		background: var(--green, #6b8f71);
		color: #fff;
		padding: 0.2em 0.6em;
		border-radius: 4px;
		font-weight: 600;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.payment-note {
		margin-left: auto;
	}

	#order-form {
		margin-bottom: 2em;
	}
	.form-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1em;
	}
	.form-field.full-width {
		grid-column: 1 / -1;
	}
	.form-field label {
		display: block;
		font-size: 0.85rem;
		font-weight: 600;
		margin-bottom: 0.3em;
	}
	.form-field input,
	.form-field select,
	.form-field textarea {
		width: 100%;
		padding: 0.6em 0.8em;
		border: 1px solid var(--border);
		border-radius: 6px;
		font-size: 1rem;
		background: var(--bg);
		color: var(--text);
		font-family: inherit;
		box-sizing: border-box;
	}
	.form-field textarea {
		resize: vertical;
	}

	.hp-field {
		position: absolute;
		left: -9999px;
	}

	.submit-btn {
		display: block;
		width: 100%;
		margin-top: 1.5em;
		padding: 0.8em;
		border: none;
		border-radius: 8px;
		background: var(--accent);
		color: #fff;
		font-size: 1.05rem;
		font-weight: 600;
		cursor: pointer;
		transition: opacity 0.2s;
	}
	.submit-btn:hover:not(:disabled) {
		opacity: 0.85;
	}
	.submit-btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	.form-error {
		color: #c0392b;
		text-align: center;
		margin-top: 1em;
	}

	.success-message {
		text-align: center;
		padding: 3em 1em;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
	}
	.success-message h2 {
		color: var(--green, #6b8f71);
	}
	.success-message p {
		color: var(--text-muted);
		max-width: 440px;
		margin: 0.5em auto 0;
		line-height: 1.6;
	}

	@media (max-width: 720px) {
		.variety-grid {
			grid-template-columns: 1fr 1fr;
		}
		.form-grid {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 440px) {
		.variety-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
