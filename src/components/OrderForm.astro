---
import type { Lang } from '../i18n/translations';
import { translations } from '../i18n/translations';
import { t } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const SUPABASE_URL = 'https://oopcaomsmuqituowxpwi.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9vcGNhb21zbXVxaXR1b3d4cHdpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ0MTU5NjUsImV4cCI6MjA4OTk5MTk2NX0.SgKEfN5Aj9Uc6dVrTIHC2IG3A-M8Iiq2KHKYMu4zYHw';
const cities = ['Espoo', 'Helsinki', 'Vantaa', 'Kirkkonummi'];

// Build variety description map from translations
const descMap: Record<string, string> = {};
const langTranslations = translations[lang];
for (const key of Object.keys(langTranslations)) {
	const match = key.match(/^order\.variety\.(.+)\.desc$/);
	if (match) {
		descMap[match[1]] = langTranslations[key];
	}
}
---

<div class="order-form-wrapper"
	data-supabase-url={SUPABASE_URL}
	data-supabase-key={SUPABASE_KEY}
	data-lang={lang}
	data-descriptions={JSON.stringify(descMap)}
	data-box-label={t(lang, 'order.form.box')}
	data-boxes-label={t(lang, 'order.form.boxes')}
>
	<h2 class="section-title">{t(lang, 'order.form.variety')}</h2>
	<div class="variety-list" id="variety-list"></div>

	<div class="order-summary" id="order-summary" hidden>
		<div class="summary-header">
			<span>{t(lang, 'order.form.total')}:</span>
			<span class="total-price">0 €</span>
		</div>
	</div>

	<div class="delivery-banner">
		<span class="delivery-free">{t(lang, 'order.delivery.free')}</span>
		<span>{t(lang, 'order.delivery.info')}</span>
		<span class="payment-note">{t(lang, 'order.payment.info')}</span>
	</div>

	<form id="order-form">
		<div class="form-grid">
			<div class="form-field">
				<label for="name">{t(lang, 'order.form.name')}</label>
				<input type="text" id="name" name="name" required />
			</div>
			<div class="form-field">
				<label for="phone">{t(lang, 'order.form.phone')}</label>
				<input type="tel" id="phone" name="phone" required />
			</div>
			<div class="form-field">
				<label for="email">{t(lang, 'order.form.email')}</label>
				<input type="email" id="email" name="email" required />
			</div>
			<div class="form-field">
				<label for="city">{t(lang, 'order.form.city')}</label>
				<select id="city" name="city" required>
					{cities.map(city => <option value={city}>{city}</option>)}
				</select>
			</div>
			<div class="form-field full-width">
				<label for="address">{t(lang, 'order.form.address')}</label>
				<input type="text" id="address" name="address" required />
			</div>
			<div class="form-field full-width">
				<label for="notes">{t(lang, 'order.form.notes')}</label>
				<textarea id="notes" name="notes" rows="3"></textarea>
			</div>
		</div>
		<div class="hp-field" aria-hidden="true">
			<input type="text" name="website" tabindex="-1" autocomplete="off" />
		</div>
		<button type="submit" class="submit-btn" disabled>{t(lang, 'order.form.submit')}</button>
		<p class="form-error" hidden>{t(lang, 'order.error')}</p>
	</form>

	<div class="success-message" hidden>
		<h2>{t(lang, 'order.success.title')}</h2>
		<p>{t(lang, 'order.success.text')}</p>
	</div>
</div>

<script is:inline>
(function () {
	var wrapper = document.querySelector('.order-form-wrapper');
	if (!wrapper) return;

	var url = wrapper.dataset.supabaseUrl;
	var key = wrapper.dataset.supabaseKey;
	var lang = wrapper.dataset.lang;
	var descriptions = JSON.parse(wrapper.dataset.descriptions || '{}');
	var boxLabel = wrapper.dataset.boxLabel || 'box';
	var boxesLabel = wrapper.dataset.boxesLabel || 'boxes';
	var list = document.getElementById('variety-list');
	var summaryEl = document.getElementById('order-summary');
	var totalEl = wrapper.querySelector('.total-price');
	var form = document.getElementById('order-form');
	var submitBtn = form.querySelector('.submit-btn');
	var errorEl = wrapper.querySelector('.form-error');
	var successEl = wrapper.querySelector('.success-message');
	var varieties = [];
	var selections = {};

	function slugify(name) {
		return name.toLowerCase().replace(/\s+/g, '-');
	}

	function updateTotal() {
		var total = 0;
		var hasItems = false;
		for (var name in selections) {
			if (selections[name] > 0) {
				hasItems = true;
				var v = varieties.find(function (x) { return x.name === name; });
				if (v) total += selections[name] * v.price_per_box;
			}
		}
		totalEl.textContent = total + ' \u20AC';
		summaryEl.hidden = !hasItems;
		submitBtn.disabled = !hasItems;
	}

	function renderCard(v) {
		var slug = slugify(v.name);
		var desc = descriptions[slug] || '';
		var imgSrc = v.image_filename ? '/images/varieties/' + v.image_filename : '';

		var card = document.createElement('div');
		card.className = 'variety-card';
		card.innerHTML =
			(imgSrc
				? '<img class="variety-img" src="' + imgSrc + '" alt="' + v.name + '" />'
				: '<div class="variety-img variety-img-placeholder"></div>') +
			'<div class="variety-body">' +
				'<div class="variety-name">' + v.name + '</div>' +
				(desc ? '<div class="variety-desc">' + desc + '</div>' : '') +
				'<div class="variety-pricing">' + v.price_per_box + ' \u20AC / 1 ' + boxLabel + ' (' + v.box_weight_kg + ' kg)</div>' +
			'</div>' +
			'<div class="variety-qty">' +
				'<div class="variety-controls">' +
					'<button type="button" class="qty-btn qty-minus" disabled>\u2212</button>' +
					'<span class="qty-value">0</span>' +
					'<button type="button" class="qty-btn qty-plus">+</button>' +
				'</div>' +
				'<div class="qty-label-text">' + boxesLabel + '</div>' +
			'</div>';

		var controls = card.querySelector('.variety-controls');
		var qtyVal = card.querySelector('.qty-value');
		var minusBtn = card.querySelector('.qty-minus');
		var plusBtn = card.querySelector('.qty-plus');

		selections[v.name] = 0;

		plusBtn.addEventListener('click', function (e) {
			e.stopPropagation();
			var qty = Math.min(20, selections[v.name] + 1);
			selections[v.name] = qty;
			qtyVal.textContent = qty;
			minusBtn.disabled = false;
			if (qty > 0) card.classList.add('selected');
			updateTotal();
		});

		minusBtn.addEventListener('click', function (e) {
			e.stopPropagation();
			var qty = Math.max(0, selections[v.name] - 1);
			selections[v.name] = qty;
			qtyVal.textContent = qty;
			minusBtn.disabled = qty <= 0;
			if (qty === 0) card.classList.remove('selected');
			updateTotal();
		});

		return card;
	}

	fetch(url + '/rest/v1/varieties?available=eq.true&select=name,type,price_per_kg,price_per_box,box_weight_kg,image_filename&order=type,name', {
		headers: { 'apikey': key },
	}).then(function (r) { return r.json(); }).then(function (rows) {
		varieties = rows;
		rows.forEach(function (v) {
			list.appendChild(renderCard(v));
		});
	});

	form.addEventListener('submit', async function (e) {
		e.preventDefault();
		errorEl.hidden = true;

		if (form.website.value) return;

		var items = [];
		var totalEur = 0;
		for (var name in selections) {
			if (selections[name] > 0) {
				var v = varieties.find(function (x) { return x.name === name; });
				var subtotal = selections[name] * v.price_per_box;
				items.push({ variety: name, quantity: selections[name], price_per_box: v.price_per_box, subtotal: subtotal });
				totalEur += subtotal;
			}
		}
		if (items.length === 0) return;

		var fd = new FormData(form);
		var itemsSummary = items.map(function (i) { return i.variety + ' x' + i.quantity; }).join(', ');
		var body = {
			customer_name: fd.get('name'),
			phone: fd.get('phone'),
			email: fd.get('email'),
			address: fd.get('address'),
			city: fd.get('city'),
			variety: itemsSummary,
			quantity: items.reduce(function (s, i) { return s + i.quantity; }, 0),
			total_eur: totalEur,
			notes: fd.get('notes') || null,
		};

		submitBtn.disabled = true;

		try {
			var res = await fetch(url + '/rest/v1/orders', {
				method: 'POST',
				headers: {
					'apikey': key,
					'Authorization': 'Bearer ' + key,
					'Content-Type': 'application/json',
					'Prefer': 'return=representation',
				},
				body: JSON.stringify(body),
			});

			if (res.ok) {
				var rows = await res.json();
				var orderId = rows[0] && rows[0].id;
				fetch(url + '/functions/v1/notify-order', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + key },
					body: JSON.stringify(Object.assign({ lang: lang, order_id: orderId, items: items }, body)),
				}).catch(function () {});
				form.hidden = true;
				list.hidden = true;
				summaryEl.hidden = true;
				wrapper.querySelector('.delivery-banner').hidden = true;
				wrapper.querySelector('.section-title').hidden = true;
				successEl.hidden = false;
			} else {
				errorEl.hidden = false;
				submitBtn.disabled = false;
			}
		} catch (err) {
			errorEl.hidden = false;
			submitBtn.disabled = false;
		}
	});
})();
</script>

<style is:global>
	.order-form-wrapper {
		max-width: 720px;
		margin: 0 auto;
	}

	.order-form-wrapper .section-title {
		margin-bottom: 0.8em;
	}

	/* Variety cards — stacked list */
	.variety-list {
		display: flex;
		flex-direction: column;
		gap: 0.75em;
		margin-bottom: 1.5em;
	}

	.variety-card {
		background: var(--card-bg);
		border: 2px solid var(--border);
		border-radius: 12px;
		padding: 0.8em;
		cursor: pointer;
		transition: border-color 0.2s, box-shadow 0.2s;
		display: flex;
		align-items: center;
		gap: 0.8em;
	}
	.variety-card:hover {
		border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
	}
	.variety-card.selected {
		border-color: var(--accent);
		box-shadow: 0 0 0 1px var(--accent);
	}

	/* Photo */
	.variety-img {
		width: 48px;
		height: 48px;
		border-radius: 8px;
		object-fit: cover;
		flex-shrink: 0;
	}
	.variety-img-placeholder {
		background: var(--bg-alt, #f2efe6);
		width: 48px;
		height: 48px;
		border-radius: 8px;
	}

	/* Description */
	.variety-body {
		flex: 1;
		min-width: 0;
	}
	.variety-name {
		font-weight: 600;
		font-size: 1rem;
	}
	.variety-desc {
		font-size: 0.82rem;
		color: var(--text-muted);
		line-height: 1.4;
		margin: 0.15em 0;
	}
	.variety-pricing {
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--accent);
	}

	/* Quantity — right side */
	.variety-qty {
		flex-shrink: 0;
		text-align: center;
		min-width: 90px;
	}
	.variety-controls {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.4em;
	}
	.qty-btn {
		width: 28px;
		height: 28px;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: var(--bg);
		color: var(--text);
		font-size: 1rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.15s;
	}
	.qty-btn:hover:not(:disabled) {
		background: var(--bg-alt, #f2efe6);
	}
	.qty-btn:disabled {
		opacity: 0.3;
		cursor: not-allowed;
	}
	.qty-value {
		font-weight: 600;
		font-size: 1rem;
		min-width: 1.2em;
		text-align: center;
	}
	.qty-label-text {
		font-size: 0.75rem;
		color: var(--text-muted);
		margin-top: 0.2em;
	}

	/* Summary */
	.order-form-wrapper .order-summary {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1em 1.5em;
		margin-bottom: 1.5em;
	}
	.order-form-wrapper .summary-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-weight: 600;
	}
	.order-form-wrapper .total-price {
		font-size: 1.3rem;
		color: var(--accent);
	}

	/* Delivery banner */
	.order-form-wrapper .delivery-banner {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1em 1.5em;
		margin-bottom: 2em;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em 1.5em;
		align-items: center;
		font-size: 0.9rem;
		color: var(--text-muted);
	}
	.order-form-wrapper .delivery-free {
		background: var(--green, #6b8f71);
		color: #fff;
		padding: 0.2em 0.6em;
		border-radius: 4px;
		font-weight: 600;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.order-form-wrapper .payment-note {
		margin-left: auto;
	}

	/* Form */
	.order-form-wrapper #order-form {
		margin-bottom: 2em;
	}
	.order-form-wrapper .form-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1em;
	}
	.order-form-wrapper .form-field.full-width {
		grid-column: 1 / -1;
	}
	.order-form-wrapper .form-field label {
		display: block;
		font-size: 0.85rem;
		font-weight: 600;
		margin-bottom: 0.3em;
	}
	.order-form-wrapper .form-field input,
	.order-form-wrapper .form-field select,
	.order-form-wrapper .form-field textarea {
		width: 100%;
		padding: 0.6em 0.8em;
		border: 1px solid var(--border);
		border-radius: 6px;
		font-size: 1rem;
		background: var(--bg);
		color: var(--text);
		font-family: inherit;
		box-sizing: border-box;
	}
	.order-form-wrapper .form-field textarea {
		resize: vertical;
	}

	.order-form-wrapper .hp-field {
		position: absolute;
		left: -9999px;
	}

	.order-form-wrapper .submit-btn {
		display: block;
		width: 100%;
		margin-top: 1.5em;
		padding: 0.8em;
		border: none;
		border-radius: 8px;
		background: var(--accent);
		color: #fff;
		font-size: 1.05rem;
		font-weight: 600;
		cursor: pointer;
		transition: opacity 0.2s;
	}
	.order-form-wrapper .submit-btn:hover:not(:disabled) {
		opacity: 0.85;
	}
	.order-form-wrapper .submit-btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	.order-form-wrapper .form-error {
		color: #c0392b;
		text-align: center;
		margin-top: 1em;
	}

	.order-form-wrapper .success-message {
		text-align: center;
		padding: 3em 1em;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
	}
	.order-form-wrapper .success-message h2 {
		color: var(--green, #6b8f71);
	}
	.order-form-wrapper .success-message p {
		color: var(--text-muted);
		max-width: 440px;
		margin: 0.5em auto 0;
		line-height: 1.6;
	}

	/* Mobile */
	@media (max-width: 520px) {
		.variety-card {
			padding: 0.6em;
			gap: 0.6em;
		}
		.variety-desc {
			display: none;
		}
		.variety-qty {
			min-width: 70px;
		}
		.order-form-wrapper .form-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
