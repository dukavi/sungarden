---
import { Image } from 'astro:assets';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/translations';

interface Props {
	lang: Lang;
	type: string;
	varieties: string[];
}

const { lang, type, varieties } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/images/varieties/**/*.{png,jpg,jpeg}', { eager: true });

function getImage(slug: string): ImageMetadata | null {
	const entry = Object.entries(allImages).find(([path]) => {
		const filename = path.split('/').pop()?.split('.')[0];
		return path.includes(`/${type}/`) && filename === slug;
	});
	return entry ? entry[1].default : null;
}
---

<div class="varieties-list">
	{varieties.map((v) => {
		const image = getImage(v);
		return (
			<div class:list={['variety-card', { 'has-image': !!image }]}>
				{image && (
					<div class="variety-image">
						<Image src={image} alt={t(lang, `varieties.${type}.${v}.name`)} width={480} height={320} />
					</div>
				)}
				<div class="variety-info">
					<h2>{t(lang, `varieties.${type}.${v}.name`)}</h2>
					<p>{t(lang, `varieties.${type}.${v}.desc`)}</p>
				</div>
			</div>
		);
	})}
</div>

<style>
	.varieties-list {
		display: flex;
		flex-direction: column;
		gap: 2em;
		max-width: 960px;
		margin: 0 auto;
	}
	.variety-card {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
	}
	.variety-card.has-image {
		display: grid;
		grid-template-columns: 320px 1fr;
	}
	.variety-image {
		overflow: hidden;
	}
	.variety-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.variety-info {
		padding: 1.5em 2em;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.variety-info h2 {
		font-size: 1.2em;
		margin-bottom: 0.5em;
	}
	.variety-info p {
		color: var(--text-muted);
		font-size: 0.95em;
		line-height: 1.7;
	}
	@media (max-width: 720px) {
		.variety-card.has-image {
			grid-template-columns: 1fr;
		}
		.variety-image {
			max-height: 240px;
		}
	}
</style>
