---
import { languages, type Lang } from '../i18n/translations';
import { getAlternateUrls } from '../i18n/utils';

interface Props {
	currentLang: Lang;
}

const { currentLang } = Astro.props;
const alternates = getAlternateUrls(Astro.url.pathname);
---

<div class="lang-switcher">
	{alternates.map(({ lang, href }) => (
		lang === currentLang ? (
			<span class="lang-current">{languages[lang]}</span>
		) : (
			<a href={href} class="lang-link">{languages[lang]}</a>
		)
	))}
</div>

<style>
	.lang-switcher {
		display: flex;
		gap: 0.4em;
		align-items: center;
		font-size: 0.7em;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}
	.lang-switcher > *:not(:last-child)::after {
		content: '/';
		margin-left: 0.4em;
		color: var(--text-muted);
		opacity: 0.4;
	}
	.lang-current {
		font-weight: 600;
		color: var(--text);
	}
	.lang-link {
		text-decoration: none;
		color: var(--text-muted);
		transition: color 0.2s ease;
	}
	.lang-link:hover {
		color: var(--text);
	}
</style>
