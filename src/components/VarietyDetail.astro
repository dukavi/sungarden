---
import { Image } from 'astro:assets';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/translations';
import EmojiReactions from './EmojiReactions.astro';
import Comments from './Comments.astro';

interface Props {
	lang: Lang;
	type: string;
	variety: string;
}

const { lang, type, variety } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/images/varieties/**/*.{png,jpg,jpeg}', { eager: true });

const images = Object.entries(allImages)
	.filter(([path]) => {
		const filename = path.split('/').pop()?.split('.')[0] || '';
		return path.includes(`/${type}/`) && (filename === variety || filename.startsWith(`${variety}-`));
	})
	.sort(([a], [b]) => a.localeCompare(b))
	.map(([, mod]) => mod.default);

const name = t(lang, `varieties.${type}.${variety}.name`);
const detailKey = `varieties.${type}.${variety}.detail`;
const detail = t(lang, detailKey);
const desc = detail !== detailKey ? detail : t(lang, `varieties.${type}.${variety}.desc`);
---

<div class="variety-detail">
	{images.length > 0 && (
		<div class="gallery">
			{images.map((img, i) => (
				<div class="gallery-item">
					<Image src={img} alt={`${name} — ${i + 1}`} width={800} height={600} data-index={i} />
				</div>
			))}
		</div>
		<div class="lightbox" id="lightbox">
			<button class="lightbox-close" id="lightbox-close">&times;</button>
			<button class="lightbox-prev" id="lightbox-prev">&#8249;</button>
			<button class="lightbox-next" id="lightbox-next">&#8250;</button>
			<img id="lightbox-img" alt="" />
		</div>
	)}
	<div class="variety-body">
		<h1>{name}</h1>
		<p class="desc">{desc}</p>
	</div>
	<p class="photo-credit">{t(lang, 'varieties.photos')}</p>
	<EmojiReactions />
	<Comments lang={lang} />
</div>

<style>
	.variety-detail {
		max-width: 960px;
		margin: 0 auto;
	}
	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1em;
		margin-bottom: 2em;
	}
	.gallery-item {
		border-radius: 8px;
		overflow: hidden;
		background: var(--card-bg);
		border: 1px solid var(--border);
	}
	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		cursor: pointer;
		transition: transform 0.3s ease;
	}
	.gallery-item img:hover {
		transform: scale(1.03);
	}
	.variety-body {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 2em;
	}
	.variety-body h1 {
		font-size: 1.6em;
		margin-bottom: 0.5em;
	}
	.desc {
		color: var(--text-muted);
		font-size: 1.05em;
		line-height: 1.8;
	}
	.photo-credit {
		text-align: center;
		color: var(--text-muted);
		font-size: 0.85em;
		margin-top: 2em;
		font-style: italic;
	}
	.lightbox {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 1000;
		background: rgba(0, 0, 0, 0.92);
		align-items: center;
		justify-content: center;
	}
	.lightbox.active {
		display: flex;
	}
	.lightbox img {
		max-width: 90vw;
		max-height: 90vh;
		object-fit: contain;
		border-radius: 4px;
	}
	.lightbox-close, .lightbox-prev, .lightbox-next {
		position: fixed;
		background: none;
		border: none;
		color: white;
		cursor: pointer;
		font-size: 2.5rem;
		padding: 0.5em;
		opacity: 0.7;
		transition: opacity 0.2s;
		z-index: 1001;
	}
	.lightbox-close:hover, .lightbox-prev:hover, .lightbox-next:hover {
		opacity: 1;
	}
	.lightbox-close {
		top: 0.5em;
		right: 0.8em;
		font-size: 3rem;
	}
	.lightbox-prev {
		left: 0.5em;
		top: 50%;
		transform: translateY(-50%);
	}
	.lightbox-next {
		right: 0.5em;
		top: 50%;
		transform: translateY(-50%);
	}
	@media (max-width: 720px) {
		.gallery {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const gallery = document.querySelector('.gallery');
	const lightbox = document.getElementById('lightbox');
	const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
	const imgs = gallery ? Array.from(gallery.querySelectorAll('img')) : [];
	let current = 0;

	function show(i: number) {
		current = (i + imgs.length) % imgs.length;
		const src = imgs[current].getAttribute('src');
		if (src) lightboxImg.src = src;
		lightbox?.classList.add('active');
	}

	gallery?.addEventListener('click', (e) => {
		const img = (e.target as HTMLElement).closest('img');
		if (!img) return;
		const i = parseInt(img.dataset.index || '0');
		show(i);
	});

	document.getElementById('lightbox-close')?.addEventListener('click', () => lightbox?.classList.remove('active'));
	document.getElementById('lightbox-prev')?.addEventListener('click', () => show(current - 1));
	document.getElementById('lightbox-next')?.addEventListener('click', () => show(current + 1));

	lightbox?.addEventListener('click', (e) => {
		if (e.target === lightbox) lightbox.classList.remove('active');
	});

	document.addEventListener('keydown', (e) => {
		if (!lightbox?.classList.contains('active')) return;
		if (e.key === 'Escape') lightbox.classList.remove('active');
		if (e.key === 'ArrowLeft') show(current - 1);
		if (e.key === 'ArrowRight') show(current + 1);
	});
</script>
