---
const pageId = Astro.url.pathname;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const pageTitle = Astro.props.title || '';
---

<section class="comments">
	<div id="cusdis_thread"
		data-host="https://cusdis.com"
		data-app-id="41d865ed-fc44-45ab-8fd7-d9d41649cb49"
		data-page-id={pageId}
		data-page-url={pageUrl}
		data-page-title={pageTitle}
		data-theme="dark"
	></div>
	<script is:inline async defer src="https://cusdis.com/js/cusdis.es.js"></script>
	<script is:inline>
		function setCusdisTheme() {
			var theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			var el = document.getElementById('cusdis_thread');
			if (el) {
				el.setAttribute('data-theme', theme);
				if (window.CUSDIS) window.CUSDIS.setTheme(theme);
			}
		}
		setCusdisTheme();
		window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', setCusdisTheme);
	</script>
</section>

<style>
	.comments {
		margin-top: 2em;
	}
	.comments :global(iframe) {
		min-height: 500px;
	}
</style>
