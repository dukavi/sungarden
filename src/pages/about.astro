---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/utils';
import aboutImage from '../images/20241006_134642.jpg';
import orchardImage from '../images/20250907_153530.jpg';
import farmLogo from '../images/logo_color.svg';

const lang = 'fi';
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${t(lang, 'about.title')} — ${t(lang, 'site.title')}`} description={t(lang, 'about.intro')} lang={lang} />
	</head>
	<body>
		<Header lang={lang} />
		<main>
			<div class="container">
				<div class="page-header">
					<img src={farmLogo.src} alt="Aurinkotarha Mustio" width="280" height="280" class="about-logo" />
					<h1>{t(lang, 'about.title')}</h1>
					<p class="intro">{t(lang, 'about.intro')}</p>
				</div>

				<div class="hero-img-wrapper">
					<Image src={aboutImage} alt="Aurinkotarha" width={1200} height={500} class="page-hero" />
				</div>

				<div class="content-section">
					<h2>{t(lang, 'about.story.title')}</h2>
					<p>{t(lang, 'about.story.text')}</p>
				</div>

				<div class="content-section with-image">
					<div>
						<h2>{t(lang, 'about.orchard.title')}</h2>
						<p>{t(lang, 'about.orchard.text')}</p>
					</div>
					<Image src={orchardImage} alt="Omenatarha" width={560} height={400} />
				</div>

				<div class="content-section">
					<h2>{t(lang, 'location.title')}</h2>
					<p>{t(lang, 'location.text')}</p>
					<p class="address">{t(lang, 'location.address')}</p>
				</div>

				<div class="content-section">
					<h2>{t(lang, 'about.contact.title')}</h2>
					<a href="https://wa.me/358405405346" target="_blank" rel="noopener noreferrer" class="whatsapp-link">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
						WhatsApp: +358 40 540 5346
					</a>
					<form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
						<input type="hidden" name="form-name" value="contact" />
						<p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
						<div class="form-field">
							<label for="name">{t(lang, 'contact.name')}</label>
							<input type="text" id="name" name="name" required />
						</div>
						<div class="form-field">
							<label for="email">{t(lang, 'contact.email')}</label>
							<input type="email" id="email" name="email" required />
						</div>
						<div class="form-field">
							<label for="message">{t(lang, 'contact.message')}</label>
							<textarea id="message" name="message" rows="5" required></textarea>
						</div>
						<button type="submit">{t(lang, 'contact.send')}</button>
					</form>
					<p class="form-success" hidden>{t(lang, 'contact.thanks')}</p>
				</div>
			</div>
		</main>
		<Footer lang={lang} />
		<script>
			const form = document.querySelector('.contact-form') as HTMLFormElement;
			const success = document.querySelector('.form-success') as HTMLElement;
			form?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const data = new FormData(form);
				try {
					await fetch('/', {
						method: 'POST',
						headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
						body: new URLSearchParams(data as any).toString(),
					});
					form.hidden = true;
					success.hidden = false;
				} catch {
					form.submit();
				}
			});
		</script>
	</body>
</html>

<style>
	main {
		padding: 6em 0;
	}
	.page-header {
		text-align: center;
		margin-bottom: 3em;
	}
	.about-logo {
		width: 180px;
		height: auto;
		margin: 0 auto 1.5em;
		display: block;
		border-radius: 8px;
	}
	.page-header h1 {
		margin-bottom: 0.4em;
	}
	.intro {
		font-size: 1.1em;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.7;
	}
	.hero-img-wrapper {
		margin-bottom: 5em;
	}
	.page-hero {
		width: 100%;
		height: 450px;
		object-fit: cover;
	}
	.content-section {
		max-width: 720px;
		margin: 0 auto 4em;
	}
	.content-section h2 {
		margin-bottom: 0.5em;
	}
	.content-section p {
		color: var(--text-muted);
	}
	.content-section.with-image {
		max-width: 100%;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5em;
		align-items: center;
	}
	.content-section.with-image img {
		width: 100%;
		height: auto;
		display: block;
	}
	.address {
		font-weight: 500;
		color: var(--accent);
	}
	.whatsapp-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: #25D366;
		font-weight: 500;
		text-decoration: none;
		margin-bottom: 1.5em;
		font-size: 1.05em;
		transition: opacity 0.2s;
	}
	.whatsapp-link:hover {
		opacity: 0.7;
	}
	.contact-form {
		display: flex;
		flex-direction: column;
		max-width: 480px;
	}
	.form-field {
		margin-bottom: 1.2em;
	}
	.form-field label {
		display: block;
		margin-bottom: 0.3em;
		font-weight: 500;
	}
	.form-field input,
	.form-field textarea {
		width: 100%;
		padding: 0.6em 0.8em;
		border: 1px solid var(--border);
		border-radius: 4px;
		font-family: inherit;
		font-size: 1em;
		background: var(--card-bg);
		color: var(--text);
	}
	.form-field textarea {
		resize: vertical;
	}
	.contact-form button[type="submit"] {
		align-self: flex-start;
		padding: 0.6em 2em;
		background: var(--green);
		color: #fff;
		border: none;
		border-radius: 4px;
		font-size: 1em;
		cursor: pointer;
		transition: opacity 0.2s;
	}
	.contact-form button[type="submit"]:hover {
		opacity: 0.85;
	}
	.form-success {
		color: var(--green);
		font-weight: 500;
	}
	@media (max-width: 720px) {
		main {
			padding: 3em 0;
		}
		.content-section.with-image {
			grid-template-columns: 1fr;
			gap: 2em;
		}
		.page-hero {
			height: 280px;
		}
	}
</style>
