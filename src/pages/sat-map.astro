---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/utils';

const lang = 'fi';
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${t(lang, 'satmap.title')} — ${t(lang, 'site.title')}`} description={t(lang, 'satmap.subtitle')} lang={lang} />
		<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
		<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
	</head>
	<body>
		<Header lang={lang} />
		<main>
			<div class="container">
				<div class="page-header">
					<h1>{t(lang, 'satmap.title')}</h1>
					<p class="subtitle">{t(lang, 'satmap.subtitle')}</p>
				</div>

				<div class="controls">
					<label>{t(lang, 'satmap.year')}</label>
					<select id="year-picker"></select>
					<span class="year-hint">{t(lang, 'satmap.year.hint')}</span>
				</div>

				<div id="loading" class="loading" hidden>
					<div class="spinner"></div>
					<span id="loading-text"></span>
				</div>

				<div id="map-container">
					<div id="map"></div>
				</div>

				<div id="legend" class="legend" hidden>
					<span class="legend-label">{t(lang, 'satmap.legend.low')}</span>
					<div class="legend-bar"></div>
					<span class="legend-label">{t(lang, 'satmap.legend.high')}</span>
					<div class="legend-ticks">
						<span>500</span>
						<span>1000</span>
						<span>1500</span>
						<span>2000</span>
						<span>2500</span>
					</div>
				</div>

				<p id="error-msg" class="nodata" hidden>{t(lang, 'satmap.nodata')}</p>
				<p class="source">{t(lang, 'satmap.source')}</p>
			</div>
		</main>
		<Footer lang={lang} />

		<script is:inline src="/js/sat-map.js"
			data-loading-text={t(lang, 'satmap.loading')}
			data-loading-month-text={t(lang, 'satmap.loading.month')}
			data-of-text={t(lang, 'satmap.of')}
		></script>
	</body>
</html>

<style>
	main {
		padding: 6em 0;
	}
	.page-header {
		text-align: center;
		margin-bottom: 3em;
	}
	.page-header h1 {
		margin-bottom: 0.4em;
	}
	.subtitle {
		color: var(--text-muted);
		font-size: 1.05em;
	}
	.controls {
		max-width: 860px;
		margin: 0 auto 1.5em;
		display: flex;
		align-items: center;
		gap: 0.75em;
	}
	.controls label {
		font-size: 0.9em;
		color: var(--text-muted);
	}
	.year-hint {
		font-size: 0.85em;
		color: var(--text-muted);
	}
	.controls select {
		font-family: inherit;
		font-size: 0.9em;
		padding: 0.4em 0.6em;
		border: 1px solid var(--border);
		border-radius: 4px;
		background: var(--card-bg);
		color: inherit;
	}
	#map-container {
		max-width: 860px;
		margin: 0 auto 1.5em;
	}
	#map {
		width: 100%;
		height: 600px;
		border-radius: 8px;
		border: 1px solid var(--border);
		z-index: 1;
	}
	.loading {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75em;
		padding: 1.5em 0;
	}
	.loading[hidden] {
		display: none;
	}
	.spinner {
		width: 24px;
		height: 24px;
		border: 2px solid var(--border);
		border-top-color: var(--accent);
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
	}
	@keyframes spin {
		to { transform: rotate(360deg); }
	}
	#loading-text {
		font-size: 0.9em;
		color: var(--text-muted);
	}
	.legend {
		max-width: 860px;
		margin: 0 auto 1.5em;
		display: flex;
		align-items: center;
		gap: 0.5em;
		flex-wrap: wrap;
		position: relative;
	}
	.legend[hidden] {
		display: none;
	}
	.legend-label {
		font-size: 0.8em;
		color: var(--text-muted);
	}
	.legend-bar {
		flex: 1;
		min-width: 200px;
		height: 14px;
		border-radius: 4px;
		background: linear-gradient(to right, rgb(49,130,189), rgb(49,189,189), rgb(49,189,80), rgb(230,160,40), rgb(210,40,40));
	}
	.legend-ticks {
		width: 100%;
		display: flex;
		justify-content: space-between;
		padding: 0 3.5em;
		font-size: 0.75em;
		color: var(--text-muted);
	}
	.nodata {
		text-align: center;
		color: var(--text-muted);
		padding: 2em 0;
	}
	.nodata[hidden] {
		display: none;
	}
	.source {
		max-width: 860px;
		margin: 0 auto;
		font-size: 0.85em;
		color: var(--text-muted);
	}
	:global(.sat-label) {
		background: none !important;
		border: none !important;
	}
	:global(.sat-label span) {
		font-size: 11px;
		font-weight: 700;
		font-family: 'DM Sans', sans-serif;
		text-shadow: -1px -1px 0 #fff, 1px -1px 0 #fff, -1px 1px 0 #fff, 1px 1px 0 #fff, 0 0 3px #fff;
		white-space: nowrap;
	}
	@media (max-width: 720px) {
		main {
			padding: 3em 0;
		}
		#map {
			height: 400px;
		}
	}
</style>
