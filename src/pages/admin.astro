---
export const prerender = false;

import BaseHead from '../components/BaseHead.astro';
import { isValidToken } from '../lib/auth';

const token = Astro.cookies.get('admin_token')?.value;
const isAuthed = isValidToken(token);
const showError = Astro.url.searchParams.has('error');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Admin" description="Admin panel" lang="en" />
		<meta name="robots" content="noindex, nofollow" />
	</head>
	<body>
		{!isAuthed ? (
			<div class="login-screen">
				<form class="login-box" method="POST" action="/api/auth">
					<h1>Admin</h1>
					<input type="password" name="password" placeholder="Password" autofocus />
					<button type="submit">Login</button>
					{showError && <p class="error">Wrong password</p>}
				</form>
			</div>
		) : (
			<div id="admin-panel">
				<header class="admin-header">
					<h1>Admin Panel</h1>
					<a href="/api/logout" class="logout-link">Logout</a>
				</header>

				<main class="admin-main">
					<h2>Quick Links</h2>
					<div class="links-grid">
						<a href="https://github.com/dukavi/sungarden" target="_blank" rel="noopener" class="link-card">
							<span class="link-icon">
								<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
							</span>
							<span class="link-label">GitHub Repo</span>
						</a>
						<a href="https://cusdis.com/dashboard/app/41d865ed-fc44-45ab-8fd7-d9d41649cb49" target="_blank" rel="noopener" class="link-card">
							<span class="link-icon">
								<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12zM7 9h2v2H7zm4 0h2v2h-2zm4 0h2v2h-2z"/></svg>
							</span>
							<span class="link-label">Cusdis Comments</span>
						</a>
						<a href="https://supabase.com/dashboard/project/oopcaomsmuqituowxpwi" target="_blank" rel="noopener" class="link-card">
							<span class="link-icon">
								<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M21 14.9c.1 1.5-1.3 2.7-2.8 2.6H5.8c-1.5.1-2.9-1.1-2.8-2.6L4.4 3.5C4.5 2.1 5.7 1 7.1 1h9.8c1.4 0 2.6 1.1 2.7 2.5L21 14.9zM12 18c-2.8 0-5 1.1-5 2.5S9.2 23 12 23s5-1.1 5-2.5S14.8 18 12 18z"/></svg>
							</span>
							<span class="link-label">Supabase DB</span>
						</a>
						<a href="https://search.google.com/search-console" target="_blank" rel="noopener" class="link-card">
							<span class="link-icon">
								<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
							</span>
							<span class="link-label">Search Console</span>
						</a>
						<a href="https://dash.cloudflare.com" target="_blank" rel="noopener" class="link-card">
							<span class="link-icon">
								<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M16.309 17.25h-1.003a.19.19 0 01-.158-.084.186.186 0 01-.024-.178l1.47-4.57a.96.96 0 00-.044-.76.99.99 0 00-.603-.503l-8.835-2.89a.202.202 0 01-.093-.065.178.178 0 01-.012-.207.193.193 0 01.075-.072l1.15-.638a1.38 1.38 0 01.96-.15l10.09 2.795a2.4 2.4 0 011.538 1.197 2.32 2.32 0 01.143 1.928l-.807 2.51a2.06 2.06 0 01-1.97 1.456l-1.877.001zm-9.812 0H4.554a2.058 2.058 0 01-1.558-.713 2.003 2.003 0 01-.445-1.645l.416-2.574a.488.488 0 01.322-.375.51.51 0 01.498.07l2.42 1.87a.188.188 0 01.072.148.183.183 0 01-.072.148l-.553.427a.376.376 0 00-.144.296.37.37 0 00.144.296.39.39 0 00.47.013l2.108-1.482a.19.19 0 01.234.006.183.183 0 01.06.222l-1.513 3.042a.232.232 0 01-.208.126l-.716.001z"/></svg>
							</span>
							<span class="link-label">Cloudflare</span>
						</a>
						<a href="https://www.domainhotelli.fi" target="_blank" rel="noopener" class="link-card">
							<span class="link-icon">
								<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
							</span>
							<span class="link-label">Domainhotelli</span>
						</a>
					</div>
				</main>
			</div>
		)}

		<style>
			body {
				margin: 0;
				font-family: 'Lora', serif;
				background: var(--bg);
				color: var(--text);
			}

			.login-screen {
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 100vh;
			}
			.login-box {
				background: var(--card-bg);
				border: 1px solid var(--border);
				border-radius: 12px;
				padding: 2.5em 2em;
				text-align: center;
				max-width: 320px;
				width: 100%;
			}
			.login-box h1 {
				font-family: 'Playfair Display', serif;
				margin: 0 0 1em;
				font-size: 1.5rem;
			}
			.login-box input {
				width: 100%;
				padding: 0.6em 0.8em;
				border: 1px solid var(--border);
				border-radius: 6px;
				font-size: 1rem;
				background: var(--bg);
				color: var(--text);
				box-sizing: border-box;
			}
			.login-box button {
				margin-top: 1em;
				width: 100%;
				padding: 0.6em;
				border: none;
				border-radius: 6px;
				background: var(--accent);
				color: #fff;
				font-size: 1rem;
				cursor: pointer;
			}
			.login-box button:hover {
				background: var(--accent-hover);
			}
			.error {
				color: #c0392b;
				margin-top: 0.8em;
				font-size: 0.9rem;
			}

			.admin-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 1em 2em;
				background: var(--footer-bg);
				color: #fff;
			}
			.admin-header h1 {
				font-family: 'Playfair Display', serif;
				font-size: 1.3rem;
				margin: 0;
			}
			.logout-link {
				background: transparent;
				border: 1px solid rgba(255,255,255,0.3);
				color: #fff;
				padding: 0.4em 1em;
				border-radius: 6px;
				font-size: 0.85rem;
				text-decoration: none;
			}
			.logout-link:hover {
				border-color: #fff;
			}

			.admin-main {
				max-width: 900px;
				margin: 2em auto;
				padding: 0 1.5em;
			}

			.admin-main h2 {
				font-family: 'Playfair Display', serif;
				font-size: 1.2rem;
				margin: 0 0 1em;
			}

			.links-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
				gap: 1em;
			}

			.link-card {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.6em;
				padding: 1.5em 1em;
				background: var(--card-bg);
				border: 1px solid var(--border);
				border-radius: 10px;
				text-decoration: none;
				color: var(--text);
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			.link-card:hover {
				border-color: var(--accent, var(--amber));
				box-shadow: 0 2px 8px rgba(0,0,0,0.08);
			}

			.link-icon {
				width: 32px;
				height: 32px;
				opacity: 0.7;
			}
			.link-icon svg {
				width: 100%;
				height: 100%;
			}

			.link-label {
				font-size: 0.9rem;
				font-weight: 600;
			}
		</style>
	</body>
</html>
