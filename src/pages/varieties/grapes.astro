---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import VarietyList from '../../components/VarietyList.astro';
import { t, getLocalePath } from '../../i18n/utils';

const lang = 'fi';
const type = 'grapes';
const varieties = ['liepsna', 'express', 'denisovskiy', 'tason', 'krasen', 'jupiter', 'pamjat-uchitelya', 'rombik', 'academic', 'charlie', 'frontenac-blanc', 'valek', 'victor', 'zilga', 'arcadia'];
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${t(lang, `varieties.${type}.title`)} — ${t(lang, 'site.title')}`} description={t(lang, `varieties.${type}.intro`)} lang={lang} />
	</head>
	<body>
		<Header lang={lang} />
		<main>
			<div class="container">
				<a href={getLocalePath(lang, '/varieties')} class="back-link">&larr; {t(lang, 'varieties.back')}</a>
				<div class="page-header">
					<h1>{t(lang, `varieties.${type}.title`)}</h1>
					<p class="intro">{t(lang, `varieties.${type}.intro`)}</p>
				</div>
				<VarietyList lang={lang} type={type} varieties={varieties} />
			</div>
		</main>
		<Footer lang={lang} />
	</body>
</html>

<style>
	main { padding: 6em 0; }
	.back-link {
		display: inline-block;
		margin-bottom: 2em;
		color: var(--accent);
		text-decoration: none;
		font-size: 0.9em;
	}
	.back-link:hover { text-decoration: underline; }
	.page-header { text-align: center; margin-bottom: 3em; }
	.page-header h1 { margin-bottom: 0.4em; }
	.intro { font-size: 1.1em; color: var(--text-muted); max-width: 600px; margin: 0 auto; line-height: 1.7; }
	@media (max-width: 720px) {
		main { padding: 3em 0; }
	}
</style>
