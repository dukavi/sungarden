---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { t } from '../../../i18n/utils';

const lang = 'en';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${t(lang, 'blog.title')} — ${t(lang, 'site.title')}`} description={t(lang, 'blog.subtitle')} lang={lang} />
	</head>
	<body>
		<Header lang={lang} />
		<main>
			<div class="container">
				<div class="page-header">
					<h1>{t(lang, 'blog.title')}</h1>
					<p class="subtitle">{t(lang, 'blog.subtitle')}</p>
				</div>
				<ul class="blog-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`} class="blog-item">
								{post.data.heroImage && (
									<Image width={720} height={400} src={post.data.heroImage} alt="" class="blog-item-img" />
								)}
								<div class="blog-item-body">
									<p class="date"><FormattedDate date={post.data.pubDate} /></p>
									<h2 class="title">{post.data.title}</h2>
									<p class="desc">{post.data.description}</p>
								</div>
							</a>
						</li>
					))}
				</ul>
			</div>
		</main>
		<Footer lang={lang} />
	</body>
</html>

<style>
	main { padding: 6em 0; }
	.page-header { text-align: center; margin-bottom: 4em; }
	.page-header h1 { margin-bottom: 0.4em; }
	.subtitle { color: var(--text-muted); font-size: 1.05em; }
	.blog-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 3em; max-width: 860px; margin: 0 auto; }
	.blog-item { display: grid; grid-template-columns: 300px 1fr; gap: 2em; text-decoration: none; color: inherit; transition: opacity 0.3s ease; }
	.blog-item:hover { opacity: 0.7; color: inherit; }
	.blog-item-img { width: 100%; height: 100%; object-fit: cover; display: block; }
	.blog-item-body { padding: 0.5em 0; display: flex; flex-direction: column; justify-content: center; }
	.title { font-size: 1.6em; margin-bottom: 0.4em; }
	.date { font-size: 0.75em; color: var(--text-muted); margin-bottom: 0.5em; text-transform: uppercase; letter-spacing: 0.1em; }
	.desc { font-size: 0.95em; color: var(--text-muted); margin: 0; line-height: 1.6; }
	@media (max-width: 720px) {
		main { padding: 3em 0; }
		.blog-item { grid-template-columns: 1fr; }
		.blog-item-img { height: 220px; }
		.blog-item-body { padding: 0; }
	}
</style>
