---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { t } from '../../i18n/utils';
import heroImage from '../../images/20241102_133932.jpg';
import aboutImage from '../../images/20240921_134845.jpg';
import locationImage from '../../images/20240915_140751.jpg';

const lang = 'sv';
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={t(lang, 'site.title')} description={t(lang, 'site.description')} lang={lang} />
	</head>
	<body>
		<Header lang={lang} />

		<section class="hero">
			<div class="hero-image-wrapper">
				<Image src={heroImage} alt="Aurinkopuutarha" width={1400} height={600} class="hero-img" />
				<div class="hero-overlay">
					<div class="container">
						<h1>{t(lang, 'hero.tagline')}</h1>
						<p>{t(lang, 'hero.subtitle')}</p>
						<a href="/sv/about" class="btn btn-primary">{t(lang, 'hero.cta')}</a>
					</div>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="container">
				<div class="two-col">
					<div>
						<h2>{t(lang, 'home.about.title')}</h2>
						<p>{t(lang, 'home.about.text')}</p>
						<a href="/sv/about" class="btn btn-outline">{t(lang, 'nav.about')}</a>
					</div>
					<div class="image-placeholder">
						<Image src={aboutImage} alt="Äppelodling" width={520} height={360} />
					</div>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="container">
				<div class="two-col reverse">
					<div class="image-placeholder">
						<Image src={locationImage} alt="Svartå Slott" width={520} height={360} />
					</div>
					<div>
						<h2>{t(lang, 'location.title')}</h2>
						<p>{t(lang, 'location.text')}</p>
						<p class="address">{t(lang, 'location.address')}</p>
					</div>
				</div>
			</div>
		</section>

		{posts.length > 0 && (
			<section class="section section-alt">
				<div class="container">
					<h2 class="text-center">{t(lang, 'blog.latest')}</h2>
					<div class="blog-grid">
						{posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="blog-card">
								{post.data.heroImage && (
									<Image width={400} height={220} src={post.data.heroImage} alt="" class="blog-card-img" />
								)}
								<div class="blog-card-body">
									<h3>{post.data.title}</h3>
									<p class="blog-date"><FormattedDate date={post.data.pubDate} /></p>
									<p>{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		)}

		<Footer lang={lang} />
	</body>
</html>

<style>
	.hero { position: relative; }
	.hero-image-wrapper { position: relative; overflow: hidden; max-height: 500px; }
	.hero-img { width: 100%; height: 500px; object-fit: cover; display: block; border-radius: 0; }
	.hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(44, 36, 22, 0.75) 0%, rgba(44, 36, 22, 0.3) 100%); display: flex; align-items: center; }
	.hero-overlay h1 { color: #ffffff; font-size: 2.8em; margin-bottom: 0.3em; font-weight: 400; }
	.hero-overlay p { color: rgba(255, 255, 255, 0.9); font-size: 1.15em; max-width: 560px; margin-bottom: 1.5em; }
	.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 3em; align-items: center; }
	.two-col.reverse { direction: rtl; }
	.two-col.reverse > * { direction: ltr; }
	.product-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2em; margin-top: 2em; }
	.product-card { background: var(--cream); border: 1px solid var(--border); border-radius: 8px; padding: 2em 1.5em; text-align: center; }
	.product-icon { font-size: 3em; margin-bottom: 0.5em; }
	.product-card h3 { font-size: 1.3em; margin-bottom: 0.5em; }
	.product-card p { font-size: 0.95em; color: var(--brown-light); margin: 0; }
	.address { font-weight: 600; color: var(--green-dark); }
	.blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2em; margin-top: 2em; }
	.blog-card { text-decoration: none; color: inherit; background: var(--cream); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; transition: box-shadow 0.2s ease, transform 0.2s ease; }
	.blog-card:hover { box-shadow: var(--box-shadow); transform: translateY(-2px); color: inherit; }
	.blog-card-img { width: 100%; height: 180px; object-fit: cover; border-radius: 0; }
	.blog-card-body { padding: 1.25em; }
	.blog-card-body h3 { font-size: 1.15em; margin-bottom: 0.3em; }
	.blog-date { font-size: 0.85em; color: var(--brown-light); margin-bottom: 0.5em; }
	.blog-card-body p:last-child { font-size: 0.9em; color: var(--brown-light); margin: 0; }
	@media (max-width: 720px) {
		.hero-overlay h1 { font-size: 1.8em; }
		.two-col { grid-template-columns: 1fr; gap: 1.5em; }
		.two-col.reverse { direction: ltr; }
		.product-grid, .blog-grid { grid-template-columns: 1fr; }
	}
</style>
