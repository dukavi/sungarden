---
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { t } from '../../i18n/utils';
import { getBlogPostsByLang, getPostSlug } from '../../lib/blog';
import heroImage from '../../images/20241102_133932.jpg';
import aboutImage from '../../images/20240921_134845.jpg';
import locationImage from '../../images/20240915_140751.jpg';

const lang = 'sv';
const posts = (await getBlogPostsByLang('fi')).slice(0, 3);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={t(lang, 'site.title')} description={t(lang, 'site.description')} lang={lang} />
	</head>
	<body>
		<Header lang={lang} />

		<section class="hero">
			<div class="hero-image-wrapper">
				<Image src={heroImage} alt="Aurinkotarha" width={1400} height={900} class="hero-img" />
				<div class="hero-overlay">
					<div class="hero-content">
						<h1>{t(lang, 'hero.tagline')}</h1>
						<p>{t(lang, 'hero.subtitle')}</p>
						<a href="/sv/about" class="btn btn-primary">{t(lang, 'hero.cta')}</a>
					</div>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="container">
				<div class="two-col">
					<div class="col-text">
						<h2>{t(lang, 'home.about.title')}</h2>
						<p>{t(lang, 'home.about.text')}</p>
						<a href="/sv/about" class="btn btn-outline">{t(lang, 'nav.about')}</a>
					</div>
					<div class="col-image">
						<Image src={aboutImage} alt="Äppelodling" width={600} height={450} />
					</div>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="container">
				<div class="two-col reverse">
					<div class="col-image">
						<Image src={locationImage} alt="Svartå Slott" width={600} height={450} />
					</div>
					<div class="col-text">
						<h2>{t(lang, 'location.title')}</h2>
						<p>{t(lang, 'location.text')}</p>
						<p class="address">{t(lang, 'location.address')}</p>
					</div>
				</div>
			</div>
		</section>

		{posts.length > 0 && (
			<section class="section section-alt">
				<div class="container">
					<h2 class="text-center">{t(lang, 'blog.latest')}</h2>
					<div class="blog-grid">
						{posts.map((post) => (
							<a href={`/blog/${getPostSlug(post)}/`} class="blog-card">
								{post.data.heroImage && (
									<Image width={400} height={280} src={post.data.heroImage} alt="" class="blog-card-img" />
								)}
								<div class="blog-card-body">
									<h3>{post.data.title}</h3>
									<p class="blog-date"><FormattedDate date={post.data.pubDate} /></p>
									<p>{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		)}

		<Footer lang={lang} />
	</body>
</html>

<style>
	.hero { position: relative; }
	.hero-image-wrapper { position: relative; overflow: hidden; height: 100vh; min-height: 600px; max-height: 800px; }
	.hero-img { width: 100%; height: 100%; object-fit: cover; display: block; }
	.hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.35) 100%); display: flex; align-items: flex-end; justify-content: flex-start; }
	.hero-content { padding: 6em 3em; max-width: 700px; }
	.hero-content h1 { color: #ffffff; font-size: 4em; margin-bottom: 0.3em; font-weight: 300; line-height: 1.05; }
	.hero-content p { color: rgba(255,255,255,0.85); font-size: 1.1em; max-width: 500px; margin-bottom: 2em; line-height: 1.6; }
	.hero-content .btn { background-color: #ffffff; color: #1a1a1a; }
	.hero-content .btn:hover { background-color: rgba(255,255,255,0.85); color: #1a1a1a; }
	.two-col { display: grid; grid-template-columns: 5fr 6fr; gap: 5em; align-items: center; }
	.two-col.reverse { grid-template-columns: 6fr 5fr; }
	.col-text h2 { margin-bottom: 0.6em; }
	.col-text p { color: var(--text-muted); margin-bottom: 1.5em; }
	.col-image img { width: 100%; height: auto; display: block; }
	.address { font-weight: 500; color: var(--accent); }
	.blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5em; margin-top: 3em; }
	.blog-card { text-decoration: none; color: inherit; display: block; transition: opacity 0.3s ease; }
	.blog-card:hover { opacity: 0.75; color: inherit; }
	.blog-card-img { width: 100%; height: 220px; object-fit: cover; display: block; margin-bottom: 1em; }
	.blog-card-body h3 { font-size: 1.3em; margin-bottom: 0.3em; }
	.blog-date { font-size: 0.8em; color: var(--text-muted); margin-bottom: 0.5em; text-transform: uppercase; letter-spacing: 0.05em; }
	.blog-card-body p:last-child { font-size: 0.9em; color: var(--text-muted); margin: 0; }
	@media (max-width: 720px) {
		.hero-image-wrapper { height: 85vh; min-height: 500px; }
		.hero-content { padding: 3em 1.5em; }
		.hero-content h1 { font-size: 2.6em; }
		.two-col, .two-col.reverse { grid-template-columns: 1fr; gap: 2em; }
		.blog-grid { grid-template-columns: 1fr; }
	}
</style>
