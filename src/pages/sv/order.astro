---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import OrderForm from '../../components/OrderForm.astro';
import { t } from '../../i18n/utils';

const lang = 'sv';
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${t(lang, 'order.title')} — ${t(lang, 'site.title')}`} description={t(lang, 'order.description')} lang={lang} />
	</head>
	<body>
		<Header lang={lang} />
		<main>
			<div class="container">
				<div class="page-header">
					<h1>{t(lang, 'order.title')}</h1>
					<p class="intro">{t(lang, 'order.intro')}</p>
				</div>
				<OrderForm lang={lang} />
			</div>
		</main>
		<Footer lang={lang} />
	</body>
</html>

<style>
	main {
		padding: 6em 0;
	}
	.page-header {
		text-align: center;
		margin-bottom: 3em;
	}
	.page-header h1 {
		margin-bottom: 0.4em;
	}
	.intro {
		font-size: 1.1em;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.7;
	}
	@media (max-width: 720px) {
		main {
			padding: 3em 0;
		}
	}
</style>
